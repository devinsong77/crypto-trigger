{
  "market": {
    "symbol": "BTCUSDT",
    "interval": "1m",
    "backfill_limit": 500,
    "max_candles": 500,
    "min_required_candles": 60
  },
  "openclaw": {
    "url": "http://127.0.0.1:18789/hooks/agent",
    "token": "CHANGE_ME",
    "name": "BTCMonitor",
    "session_key_prefix": "hook:market:",
    "deliver": true,
    "channel": "last",
    "wake_mode": "now",
    "timeout_seconds": 20
  },
  "rules": [
    {
      "id": "momentum_up",
      "title": "短线向上动量",
      "type": "combo",
      "cooldown_secs": 900,
      "all_of": [
        {
          "type": "price_change_pct",
          "lookback_bars": 3,
          "threshold_pct": 0.8,
          "direction": "up"
        },
        {
          "type": "volume_spike",
          "multiple": 2.0
        }
      ]
    },
    {
      "id": "momentum_down",
      "title": "短线向下动量",
      "type": "combo",
      "cooldown_secs": 900,
      "all_of": [
        {
          "type": "price_change_pct",
          "lookback_bars": 3,
          "threshold_pct": 0.8,
          "direction": "down"
        },
        {
          "type": "volume_spike",
          "multiple": 2.0
        }
      ]
    }
  ]
}