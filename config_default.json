{
  "market": {
    "symbol": "BTCUSDT",
    "interval": "1m",
    "backfill_limit": 500,
    "max_candles": 500,
    "min_required_candles": 60
  },
  "openclaw": {
    "url": "http://127.0.0.1:18789/hooks/agent",
    "token": "CHANGE_ME",
    "name": "BTCMonitor",
    "session_key_prefix": "hook:market:",
    "deliver": true,
    "channel": "last",
    "wake_mode": "now",
    "timeout_seconds": 20
  },
  "rules": [
    {
      "id": "btc_fast_drop",
      "title": "短线急跌",
      "type": "price_change_pct",
      "lookback_bars": 5,
      "threshold_pct": 1.2,
      "direction": "down",
      "cooldown_secs": 900
    },
    {
      "id": "btc_macd_bull_cross",
      "title": "MACD 金叉",
      "type": "macd_cross",
      "direction": "bullish",
      "cooldown_secs": 1800
    },
    {
      "id": "btc_bb_break",
      "title": "布林带突破",
      "type": "bollinger_break",
      "cooldown_secs": 1200
    }
  ]
}